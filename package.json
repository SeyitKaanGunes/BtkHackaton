{
  "name": "finshadow",
  "version": "0.1.0",
  "private": true,
  "description": "FINSHADOW AI Financial Digital Twin monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev:mobile": "npm run start -w apps/mobile",
    "build": "npm run build -ws --if-present",
    "lint": "npm run lint -ws --if-present",
    "test": "npm run test -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present",
    "check:no-env": "git diff --cached --name-only | grep -E '(^|/)\\.env($|\\.)' | grep -vE '(^|/)\\.env\\.example$' && exit 1 || exit 0"
  },
  "dependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-svg": "15.15.3"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "overrides": {
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-svg": "15.15.3"
  }
}
