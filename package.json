{
  "name": "fintwin",
  "version": "0.1.0",
  "private": true,
  "description": "Fintwin AI Financial Digital Twin monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev:local": "node scripts/dev-local.mjs",
    "dev:mobile": "npm run start -w apps/mobile",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema apps/api/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema apps/api/prisma/schema.prisma",
    "db:migrate:status": "prisma migrate status --schema apps/api/prisma/schema.prisma",
    "check:no-env": "node scripts/check-no-env.mjs",
    "smoke:integrations": "node scripts/smoke-integrations.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-svg": "15.15.3"
  },
  "devDependencies": {
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "overrides": {
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-svg": "15.15.3"
  }
}
