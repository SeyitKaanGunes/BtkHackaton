{
  "name": "@fintwin/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "npm run build -w @fintwin/shared && next build",
    "lint": "npm run build -w @fintwin/shared && next typegen && tsc -p tsconfig.json --noEmit",
    "typecheck": "npm run build -w @fintwin/shared && next typegen && tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@fintwin/shared": "0.1.0",
    "@gsap/react": "^2.1.2",
    "gsap": "^3.15.0",
    "lucide-react": "^0.562.0",
    "next": "^16.0.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
