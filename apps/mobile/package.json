{
  "name": "@finshadow/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "ios": "react-native run-ios",
    "android": "react-native run-android",
    "build": "npm run typecheck",
    "lint": "npm run typecheck",
    "typecheck": "npm --prefix \"$(git rev-parse --show-toplevel)\" run build -w @finshadow/shared && tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@finshadow/shared": "0.1.0",
    "lucide-react-native": "^0.562.0",
    "react": "^19.2.0",
    "react-native": "^0.83.6",
    "react-native-image-picker": "^8.2.1",
    "react-native-svg": "^15.15.3",
    "react-native-tts": "^4.1.1"
  },
  "devDependencies": {
    "@react-native/babel-preset": "^0.83.6",
    "@react-native/metro-config": "^0.83.6",
    "@react-native-community/cli": "^20.0.2",
    "@types/react": "^19.2.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
