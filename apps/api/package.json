{
  "name": "@fintwin/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start:dev": "npm run build -w @fintwin/shared && tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "npm run build -w @fintwin/shared && tsc -p tsconfig.json",
    "lint": "npm run build -w @fintwin/shared && tsc -p tsconfig.json --noEmit",
    "typecheck": "npm run build -w @fintwin/shared && tsc -p tsconfig.json --noEmit",
    "test": "npm run build -w @fintwin/shared && vitest run",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@fintwin/shared": "0.1.0",
    "@langchain/core": "^1.0.6",
    "@langchain/langgraph": "^1.3.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.19",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "openai": "^4.79.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
