NODE_ENV=production
PORT=4000
API_CORS_ORIGINS="https://your-web-domain.com"

# Supabase / Postgres
# Runtime should use the transaction pooler.
DATABASE_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma migrations should use direct connection or session pooler.
DIRECT_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-<region>.pooler.supabase.com:5432/postgres"

JWT_SECRET="generate-a-random-secret-with-at-least-32-characters"

# Required: real Gemini API key. Used by chat, vision, document extraction, and TTS.
GEMINI_API_KEY=""
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
GEMINI_TEXT_MODEL="gemini-3-flash-preview"
GEMINI_VISION_MODEL="gemini-3-flash-preview"
GEMINI_SECONDARY_MODEL="gemini-2.5-flash"
GEMINI_STT_MODEL="gemini-2.5-flash"
GEMINI_TTS_MODEL="gemini-3.1-flash-tts-preview"
GEMINI_TTS_VOICE="Kore"

GOOGLE_OAUTH_CLIENT_ID="your-google-oauth-web-client-id"
FCM_PROJECT_ID="optional-firebase-project-id"
# Required: real Twelve Data API key for portfolio pricing. Production rejects placeholder values.
TWELVE_DATA_API_KEY=""
