NODE_ENV=production
PORT=4000
API_CORS_ORIGINS="https://your-web-domain.com"

# Supabase / Postgres
# Runtime should use the transaction pooler.
DATABASE_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma schema pushes should use direct connection or session pooler.
DIRECT_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-<region>.pooler.supabase.com:5432/postgres"

JWT_SECRET="generate-a-random-secret-with-at-least-32-characters"

# Required: real DashScope/Qwen API key. Production rejects placeholder values.
QWEN_API_KEY=""
QWEN_BASE_URL="https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
QWEN_TEXT_MODEL="qwen3.6-flash-2026-04-16"
QWEN_VISION_MODEL="qwen3.6-flash-2026-04-16"
QWEN_SECONDARY_MODEL="qwen3.6-flash"

GOOGLE_OAUTH_CLIENT_ID="optional-google-oauth-client-id"
GOOGLE_OAUTH_CLIENT_SECRET="optional-google-oauth-client-secret"
FCM_PROJECT_ID="optional-firebase-project-id"
# Required: real Twelve Data API key for portfolio pricing. Production rejects placeholder values.
TWELVE_DATA_API_KEY=""
